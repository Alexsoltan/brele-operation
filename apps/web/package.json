{
  "name": "@brele-operations/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3100",
    "clean": "rm -rf .next",
    "dev:clean": "rm -rf .next && next dev --port 3100",
    "build": "next build",
    "start": "next start",
    "check": "tsc --noEmit",
    "daily:chat-summaries": "tsx scripts/generate-daily-chat-summaries.ts",
    "daily:project-signals": "tsx scripts/generate-daily-project-signals.ts",
    "daily:operations": "pnpm daily:chat-summaries && pnpm daily:project-signals"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "lucide-react": "0.468.0",
    "next": "14.2.23",
    "pg": "^8.20.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "20.17.10",
    "@types/pg": "^8.20.0",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.23",
    "postcss": "8.4.49",
    "prisma": "^7.8.0",
    "tailwindcss": "3.4.17",
    "tsx": "^4.21.0",
    "typescript": "5.7.2"
  }
