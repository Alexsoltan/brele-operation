generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MANAGER
  ANALYST
}

enum ProjectStatus {
  active
  hold
  archived
}

enum Mood {
  good
  neutral
  bad
}

enum Risk {
  low
  medium
  high
}

enum MeetingAnalysisStatus {
  pending
  analyzed
  manual
  error
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  users                 User[]
  projects              Project[]
  meetings              Meeting[]
  meetingTypes          MeetingType[]
  projectScoringConfigs ProjectScoringConfig[]

  @@index([deletedAt])
}

model User {
  id           String   @id @default(cuid())
  workspaceId  String?

  email        String   @unique
  name         String?
  role         UserRole @default(ANALYST)
  passwordHash String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  workspace    Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([role])
  @@index([deletedAt])
}

model Project {
  id          String        @id @default(cuid())
  workspaceId String?

  slug        String        @unique
  name        String
  client      String?
  status      ProjectStatus @default(active)

  clientMood  Mood @default(neutral)
  teamMood    Mood @default(neutral)
  risk        Risk @default(low)

  healthScore        Int      @default(100)
  healthTrend        String   @default("flat")
  healthLabel        String   @default("stable")
  healthSummary      String?
  healthCalculatedAt DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace    Workspace?           @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  meetings     Meeting[]
  healthPoints ProjectHealthPoint[]

  @@index([workspaceId])
  @@index([deletedAt])
  @@index([healthScore])
  @@index([healthLabel])
}
model MeetingType {
  id          String @id @default(cuid())
  workspaceId String?

  name        String
  slug        String
  description String?
  prompt      String
  isDefault   Boolean @default(false)
  hasClient   Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  meetings  Meeting[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@index([deletedAt])
}

model Meeting {
  id            String @id @default(cuid())
  workspaceId   String?
  projectId     String
  meetingTypeId String?

  title       String
  date        DateTime
  meetingType String
  hasClient   Boolean @default(true)

  transcriptText String?
  summary        String
  highlights     String[] @default([])

  clientMood Mood @default(neutral)
  teamMood   Mood @default(neutral)
  risk       Risk @default(low)

  analysisStatus MeetingAnalysisStatus @default(pending)
  modelName       String?
  analyzedAt      DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  workspace Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      MeetingType? @relation(fields: [meetingTypeId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([projectId])
  @@index([meetingTypeId])
  @@index([date])
  @@index([hasClient])
  @@index([deletedAt])
}

model ProjectScoringConfig {
  id          String @id @default(cuid())
  workspaceId String?

  key       String
  label     String
  group     String
  value     Float
  sortOrder Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, key])
  @@index([workspaceId])
  @@index([group])
  @@index([sortOrder])
}

model ProjectHealthPoint {
  id        String @id @default(cuid())
  projectId String

  date   DateTime
  score  Int
  delta  Int
  impact Int

  risk       Risk
  clientMood Mood
  teamMood   Mood
  hasClient  Boolean @default(true)

  meetingId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, date, meetingId])
  @@index([projectId])
  @@index([date])
  @@index([score])
}