generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MANAGER
  ANALYST
}

enum ProjectStatus {
  active
  hold
  archived
}

enum Mood {
  good
  neutral
  bad
}

enum Risk {
  low
  medium
  high
}

enum MeetingAnalysisStatus {
  pending
  analyzed
  manual
  error
}

enum ProjectChatParticipantRole {
  client
  team
  unknown
  ignore
}

enum PromptConfigKey {
  meeting_analysis
  chat_daily_summary
  signal_extraction_from_meeting
  signal_extraction_from_chat
  project_health_summary
}

enum SignalSource {
  meeting
  chat
  manual
}

enum SignalCategory {
  client
  team
  delivery
  business
  communication
  process
  opportunity
}

enum SignalType {
  client_satisfaction
  client_dissatisfaction
  client_trust
  team_confidence
  team_demotivation
  deadline_risk
  scope_change
  quality_issue
  blocker
  budget_risk
  communication_gap
  decision_made
  escalation
  positive_feedback
  upsell_opportunity
}

enum SignalDirection {
  positive
  negative
  neutral
}

enum SignalSeverity {
  info
  low
  medium
  high
  critical
}

enum SignalStatus {
  active
  resolved
  dismissed
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  users                 User[]
  projects              Project[]
  meetings              Meeting[]
  meetingTypes          MeetingType[]
  projectScoringConfigs ProjectScoringConfig[]
  promptConfigs         PromptConfig[]
  signalWeightConfigs   SignalWeightConfig[]

  @@index([deletedAt])
}

model User {
  id           String   @id @default(cuid())
  workspaceId  String?

  email        String   @unique
  name         String?
  role         UserRole @default(ANALYST)
  passwordHash String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  workspace    Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([role])
  @@index([deletedAt])
}
model Project {
  id          String        @id @default(cuid())
  workspaceId String?

  slug        String        @unique
  name        String
  client      String?
  status      ProjectStatus @default(active)

  clientMood  Mood @default(neutral)
  teamMood    Mood @default(neutral)
  risk        Risk @default(low)

  healthScore        Int      @default(100)
  healthTrend        String   @default("flat")
  healthLabel        String   @default("stable")
  healthSummary      String?
  healthCalculatedAt DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace          Workspace?           @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  meetings           Meeting[]
  healthPoints       ProjectHealthPoint[]
  projectChats       ProjectChat[]
  chatDailySummaries ChatDailySummary[]
  signals            ProjectSignal[]

  @@index([workspaceId])
  @@index([deletedAt])
  @@index([healthScore])
  @@index([healthLabel])
}

model MeetingType {
  id          String @id @default(cuid())
  workspaceId String?

  name        String
  slug        String
  description String?
  prompt      String
  isDefault   Boolean @default(false)
  hasClient   Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  meetings  Meeting[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@index([deletedAt])
}

model Meeting {
  id            String @id @default(cuid())
  workspaceId   String?
  projectId     String
  meetingTypeId String?

  title       String
  date        DateTime
  meetingType String
  hasClient   Boolean @default(true)

  transcriptText String?
  summary        String
  highlights     String[] @default([])

  clientMood Mood @default(neutral)
  teamMood   Mood @default(neutral)
  risk       Risk @default(low)

  analysisStatus MeetingAnalysisStatus @default(pending)
  modelName       String?
  analyzedAt      DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  workspace Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      MeetingType? @relation(fields: [meetingTypeId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([projectId])
  @@index([meetingTypeId])
  @@index([date])
  @@index([hasClient])
  @@index([deletedAt])
}
model ProjectScoringConfig {
  id          String @id @default(cuid())
  workspaceId String?

  key       String
  label     String
  group     String
  value     Float
  sortOrder Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, key])
  @@index([workspaceId])
  @@index([group])
  @@index([sortOrder])
}

model ProjectHealthPoint {
  id        String @id @default(cuid())
  projectId String

  date   DateTime
  score  Int
  delta  Int
  impact Int

  risk       Risk
  clientMood Mood
  teamMood   Mood
  hasClient  Boolean @default(true)

  meetingId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, date, meetingId])
  @@index([projectId])
  @@index([date])
  @@index([score])
}

model ProjectChat {
  id             String @id @default(cuid())
  projectId      String
  telegramChatId String @unique

  title    String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project      Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages     ChatMessage[]
  participants ProjectChatParticipant[]

  @@index([projectId])
  @@index([telegramChatId])
  @@index([isActive])
}
model ChatMessage {
  id            String @id @default(cuid())
  projectChatId String

  telegramMessageId String
  authorTelegramId  String?
  authorUsername    String?
  authorName        String?

  text String
  date DateTime

  createdAt DateTime @default(now())

  chat ProjectChat @relation(fields: [projectChatId], references: [id], onDelete: Cascade)

  @@unique([projectChatId, telegramMessageId])
  @@index([projectChatId])
  @@index([date])
}

model ChatDailySummary {
  id        String @id @default(cuid())
  projectId String

  date DateTime

  clientMood Mood @default(neutral)
  teamMood   Mood @default(neutral)
  risk       Risk @default(low)

  summary    String
  highlights String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, date])
  @@index([projectId])
  @@index([date])
  @@index([risk])
}

model ProjectChatParticipant {
  id            String @id @default(cuid())
  projectChatId String

  telegramUserId String
  username       String?
  name           String?
  role           ProjectChatParticipantRole @default(unknown)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chat ProjectChat @relation(fields: [projectChatId], references: [id], onDelete: Cascade)

  @@unique([projectChatId, telegramUserId])
  @@index([projectChatId])
  @@index([role])
}

model PromptConfig {
  id          String @id @default(cuid())
  workspaceId String?

  key         PromptConfigKey
  label       String
  description String?
  systemPrompt String
  userPrompt   String
  modelName    String?
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, key])
  @@index([workspaceId])
  @@index([key])
  @@index([isActive])
}

model ProjectSignal {
  id        String @id @default(cuid())
  projectId String

  source   SignalSource
  sourceId String?

  category  SignalCategory
  type      SignalType
  direction SignalDirection
  severity  SignalSeverity
  status    SignalStatus @default(active)

  title String
  text  String

  confidence Float?

  occurredAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([source])
  @@index([type])
  @@index([severity])
  @@index([status])
  @@index([occurredAt])
}

model SignalWeightConfig {
  id          String @id @default(cuid())
  workspaceId String?

  type SignalType
  weight           Float
  clientMoodImpact Float @default(0)
  teamMoodImpact   Float @default(0)
  
  label     String?
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, type])
  @@index([workspaceId])
  @@index([type])
  @@index([isActive])
}